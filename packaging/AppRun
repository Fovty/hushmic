#!/bin/bash
HERE="$(dirname "$(readlink -f "$0")")"
export LD_LIBRARY_PATH="$HERE/usr/lib:${LD_LIBRARY_PATH:-}"
export ORT_DYLIB_PATH="$HERE/usr/lib/libonnxruntime.so"
export HUSHMIC_PLUGIN_SO="$HERE/usr/lib/ladspa/libdpdfnet_ladspa.so"
export HUSHMIC_MODEL_DIR="$HERE/usr/share/hushmic/models"
exec "$HERE/usr/bin/hushmic" "$@"
